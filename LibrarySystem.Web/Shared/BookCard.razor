@using LibrarySystem.Core

<div class="card mb-3 @(Book.IsAvailable ? "border-success" : "border-danger")">
    <div class="card-body">
        <h5 class="card-title">@Book.Title</h5>
        <p class="card-text">@Book.Author (@Book.PublishedYear)</p>
        <p class="card-text"><small>ISBN: @Book.ISBN</small></p>
        <span class="badge @(Book.IsAvailable ? "bg-success" : "bg-danger")">
            @(Book.IsAvailable ? "Tillgänglig" : "Utlånad")
        </span>
        <div class="mt-2">
            <a href="books/@Book.Id" class="btn btn-sm btn-info">Detaljer</a>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Book Book { get; set; } = default!;
}
